# ============================================
# RepostAI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- OpenAI ---
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- Razorpay (payments) ---
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id
# Webhook secret from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Plan IDs (create in Razorpay Dashboard → Subscriptions → Plans)
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxx
RAZORPAY_PLAN_PRO_ANNUAL=plan_xxx
RAZORPAY_PLAN_AGENCY_MONTHLY=plan_xxx
RAZORPAY_PLAN_AGENCY_ANNUAL=plan_xxx

# --- Email (Resend) ---
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=support@repostai.com

# --- Rate limiting (Upstash Redis) ---
# Get these from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Error Tracking (Sentry) ---
# Get from: https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=optional-for-source-maps

# --- Analytics (PostHog) ---
# Get from: PostHog → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Social / OAuth (LinkedIn, Twitter) ---
# LinkedIn: https://www.linkedin.com/developers/apps → your app → Auth. Add redirect: {NEXT_PUBLIC_APP_URL}/api/connect/linkedin/callback
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Twitter: https://developer.twitter.com → your app. Add callback: {NEXT_PUBLIC_APP_URL}/api/connect/twitter/callback
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# --- App Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RepostAI
